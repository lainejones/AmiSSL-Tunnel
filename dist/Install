; ===========================================================================
; AmiSSL-Tunnel - Installer Script
; Installs the LAN TLS-offload shim (amissl.library + amisslmaster.library)
; and points it at your daemon via ENV:/ENVARC:AMISSLPROXY.
; Requires Installer 43.3+ (standard with AmigaOS 2.0+).
;
; Run from inside the extracted archive folder, or:  Installer Install
; ===========================================================================

(complete 0)

(message
    "AmiSSL-Tunnel - LAN TLS offload\n\n"
    "This installs a drop-in amissl.library + amisslmaster.library that "
    "offload HTTPS/TLS to a daemon (tls_proxy.py) running on a fast machine "
    "on your LAN, so iBrowse / AWeb / Amelinium can do https:// on a plain "
    "68k Amiga.\n\n"
    "You will need:\n"
    "  - a working TCP/IP stack (Roadshow, AmiTCP, Miami, a314bsd)\n"
    "  - the daemon running on a LAN box (its IP and port)\n\n"
    "Click Proceed to continue."
)

; -------------------------------------------------------
; Sanity check - are we in the archive folder?
; -------------------------------------------------------
(if (not (exists "amissl.library"))
    (abort
        "Could not find amissl.library.\n\n"
        "Please run this Installer from inside the extracted "
        "AmiSSL-Tunnel archive folder."
    )
)
(if (not (exists "amisslmaster.library"))
    (abort
        "Could not find amisslmaster.library.\n\n"
        "Please run this Installer from inside the extracted "
        "AmiSSL-Tunnel archive folder."
    )
)

(complete 10)

; -------------------------------------------------------
; Require a TCP/IP stack (bsdsocket.library)
; -------------------------------------------------------
(if (not (exists "LIBS:bsdsocket.library"))
    (if (= 1 (askbool
            (prompt
                "bsdsocket.library was not found in LIBS:.\n\n"
                "AmiSSL-Tunnel needs a working TCP/IP stack (Roadshow, AmiTCP, "
                "Miami, or a314bsd). Some stacks keep bsdsocket.library "
                "resident rather than in LIBS:.\n\n"
                "If you are sure your stack is set up, choose Continue.")
            (help
                "All network I/O goes through the resident bsdsocket.library. "
                "If your stack provides it resident (not as a file in LIBS:) "
                "this check is harmless - choose Continue. Otherwise install "
                "your TCP/IP stack first.")
            (default 0)
            (choices "Continue" "Abort")))
        (abort
            "Install your TCP/IP stack (bsdsocket.library) first, "
            "then re-run this Installer."
        )
    )
)

(complete 20)

; -------------------------------------------------------
; Back up any existing AmiSSL libraries, then install the shim.
; (The shim REPLACES amissl.library / amisslmaster.library. Backups are
;  saved as .bak so you can restore real AmiSSL later if you want.)
; -------------------------------------------------------
(if (exists "LIBS:amisslmaster.library")
    (
        (message
            "An existing LIBS:amisslmaster.library was found.\n\n"
            "It will be backed up to LIBS:amisslmaster.library.bak "
            "before the AmiSSL-Tunnel shim is installed.")
        (run "Copy >NIL: LIBS:amisslmaster.library LIBS:amisslmaster.library.bak CLONE")
    )
)
(if (exists "LIBS:amissl.library")
    (run "Copy >NIL: LIBS:amissl.library LIBS:amissl.library.bak CLONE")
)

(message "Installing amisslmaster.library to LIBS: ...")
(run "Copy amisslmaster.library LIBS: CLONE")

(message "Installing amissl.library to LIBS: ...")
(run "Copy amissl.library LIBS: CLONE")

(complete 50)

; -------------------------------------------------------
; Daemon address -> ENV:/ENVARC:AMISSLPROXY
; -------------------------------------------------------
(set daemon_host
    (askstring
        (prompt
            "Enter the IP address (or hostname) of the machine running the "
            "AmiSSL-Tunnel daemon (tls_proxy.py).\n\n"
            "This is the LAN box that performs the TLS for you.")
        (help
            "The daemon runs on a fast machine on your LAN - a Linux box, "
            "Raspberry Pi, Mac, or PC running tls_proxy.py.\n\n"
            "Enter its LAN IP address, e.g. 192.168.1.50. A hostname also "
            "works if your TCP/IP stack can resolve it.")
        (default "192.168.1.50")
    )
)

(set daemon_port
    (askstring
        (prompt
            "Enter the daemon's TCP port.\n\n"
            "Default: 8443 (matches tls_proxy.py's default).")
        (help
            "This is the port tls_proxy.py listens on. Leave it at 8443 "
            "unless you changed it on the daemon side.")
        (default "8443")
    )
)

(complete 75)

; -------------------------------------------------------
; Write the address. ENVARC: persists across reboot; ENV: activates it now.
; resolve_daemon() in the shim strips the trailing newline echo adds.
; -------------------------------------------------------
(message "Saving daemon address to ENVARC:AMISSLPROXY (persistent) ...")
(run "echo " ^ daemon_host ^ ":" ^ daemon_port ^ " >ENVARC:AMISSLPROXY")

(message "Activating ENV:AMISSLPROXY for this session ...")
(run "echo " ^ daemon_host ^ ":" ^ daemon_port ^ " >ENV:AMISSLPROXY")

(complete 100)

; -------------------------------------------------------
; Done
; -------------------------------------------------------
(message
    "AmiSSL-Tunnel installation complete!\n\n"
    "Installed:\n"
    "  LIBS:amissl.library\n"
    "  LIBS:amisslmaster.library\n"
    "  ENV:AMISSLPROXY    = " daemon_host ":" daemon_port "\n"
    "  ENVARC:AMISSLPROXY (persistent)\n\n"
    "Next:\n"
    "  1. Make sure tls_proxy.py is running on " daemon_host ":" daemon_port "\n"
    "  2. Make sure your TCP/IP stack is up\n"
    "  3. Launch iBrowse / AWeb / Amelinium and load an https:// site\n\n"
    "To change the daemon address later, re-run this Installer or edit "
    "ENVARC:AMISSLPROXY (then reboot or copy it to ENV:).\n\n"
    "If real AmiSSL was previously installed, it was backed up as "
    "LIBS:amissl(master).library.bak."
)

(exit)
